# Dependency-Track is an optional demonstration backend, not a DTVP service.
# Generate a random database password before starting the demo.
DTVP_DEMO_DEPENDENCY_TRACK_DATABASE_PASSWORD=

# After first login, create a least-privilege service-team API key and restart
# DTVP with it. Archive imports require a separate key with BOM upload rights.
DTVP_DEMO_DEPENDENCY_TRACK_API_KEY=
DTVP_DEMO_DEPENDENCY_TRACK_IMPORT_API_KEY=
DTVP_DEMO_DEPENDENCY_TRACK_ID=dependency-track-demo
DTVP_DEMO_DEPENDENCY_TRACK_LABEL=Dependency-Track Demo
