DTVP_ENVIRONMENT=test
DTVP_VULNERABILITY_BACKEND_ID=dependency-track
DTVP_VULNERABILITY_BACKEND_TYPE=dependency-track
DTVP_VULNERABILITY_BACKEND_LABEL=Dependency-Track Test
DTVP_VULNERABILITY_BACKEND_API_KEY=xxx
DTVP_VULNERABILITY_BACKEND_API_URL=https://xxx.yyy
DTVP_OIDC_AUTHORITY=https://xxx.yyy
DTVP_CONTEXT_PATH=/
DTVP_FRONTEND_URL=http://localhost:8000
DTVP_OIDC_REDIRECT_URI=http://localhost:8000/auth/callback
DTVP_SESSION_SECRET_KEY=test-only-session-secret-that-is-long-enough-1234567890
DTVP_OIDC_CLIENT_ID=xxx
DTVP_OIDC_CLIENT_SECRET=xxx

# Project archive export/import and scheduled snapshot defaults for tests
DTVP_PROJECT_ARCHIVE_PATH=data/project_archives.test
DTVP_PROJECT_ARCHIVE_EXPANDED_ENABLED=false
DTVP_PROJECT_ARCHIVE_EXPANDED_PATH=data/project_archives_git.test
DTVP_PROJECT_ARCHIVE_SNAPSHOT_ENABLED=false
DTVP_PROJECT_ARCHIVE_INTERVAL_SECONDS=86400
DTVP_PROJECT_ARCHIVE_RETENTION_COUNT=30
DTVP_PROJECT_ARCHIVE_INCLUDE=

# Threat-model rescoring integration (keep disabled in CI/local test env unless explicitly configured)
DTVP_TMRESCORE_URL=
DTVP_TMRESCORE_TIMEOUT_SECONDS=180
DTVP_TMRESCORE_CACHE_PATH=data/tmrescore_proposals.test.json
DTVP_TMRESCORE_OLLAMA_MODEL=qwen2.5:7b
DTVP_TMRESCORE_TASK_TTL_SECONDS=300

# Agentyzer code analysis integration (keep disabled unless explicitly configured)
DTVP_AGENTYZER_URL=
DTVP_AGENTYZER_TIMEOUT_SECONDS=300

DTVP_BUILD_COMMIT=test
# Set a default project filter for the dashboard
DTVP_DEFAULT_PROJECT_FILTER=
# Comma-separated attribution-age filter presets for project filters
DTVP_ATTRIBUTION_AGE_FILTER_DAYS=7d,14d,28d
