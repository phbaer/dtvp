# Prefer immutable release tags or digests for Git-managed deployments.
DTVP_IMAGE=git.baer.one/phbaer/dtvp:latest
AGENTYZER_IMAGE=git.baer.one/phbaer/agentyzer:latest

# Bind to 127.0.0.1 when a reverse proxy runs on the Docker host. Use 0.0.0.0
# only when DTVP should be reachable directly from other hosts.
DTVP_HTTP_BIND_ADDRESS=127.0.0.1
DTVP_HTTP_PORT=8000

# Secrets are converted to files and mounted only into the services that need
# them. Keep this file in Arcane; do not commit a populated copy.
DTVP_VULNERABILITY_BACKEND_API_KEY=
DTVP_VULNERABILITY_BACKEND_IMPORT_API_KEY=
DTVP_SESSION_SECRET_KEY=
DTVP_SESSION_PREVIOUS_SECRET_KEY=
DTVP_OIDC_CLIENT_SECRET=
AGENTYZER_SERVICE_TOKEN=
AGENTYZER_ADMIN_TOKEN=
AGENTYZER_OPENWEBUI_API_KEY=
