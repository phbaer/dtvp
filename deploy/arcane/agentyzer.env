# Non-secret Agentyzer runtime configuration. Git-managed deployments may
# customize this file in their deployment branch.
AGENTYZER_CONFIG_DIR=/app/config
AGENTYZER_REPOS_DIR=/app/repos
AGENTYZER_ENVIRONMENT=production
AGENTYZER_LOG_LEVEL=INFO

# LLM provider. The API key, when needed, is supplied separately.
AGENTYZER_LLM_BACKEND=ollama
AGENTYZER_OLLAMA_HOST=http://host.docker.internal:11434
AGENTYZER_OLLAMA_MODEL=mistral
AGENTYZER_OPENWEBUI_HOST=http://host.docker.internal:3000
AGENTYZER_OPENWEBUI_MODEL=mistral
AGENTYZER_OPENWEBUI_TOOL_CALLS=auto
AGENTYZER_OPENWEBUI_CONTEXT_WINDOW=0
AGENTYZER_OPENWEBUI_CONTEXT_SAFETY_MARGIN=256
AGENTYZER_OPENWEBUI_CONTEXT_RETRIES=2
AGENTYZER_OPENWEBUI_MIN_COMPLETION_TOKENS=256

# Queue and disposable repository-cache policy.
AGENTYZER_MAX_CONCURRENT_JOBS=1
AGENTYZER_MAX_QUEUED_JOBS=100
AGENTYZER_MAX_ACTIVE_JOBS_PER_OWNER=10
AGENTYZER_WORKTREE_RETENTION_SECONDS=86400
AGENTYZER_JOB_STORE_PATH=/app/repos/agentyzer_jobs.sqlite
AGENTYZER_INSTANCE_LOCK_PATH=/app/repos/.agentyzer-runtime.lock
AGENTYZER_STORAGE_MIN_FREE_BYTES=134217728
AGENTYZER_JOB_RETENTION_SECONDS=604800
AGENTYZER_JOB_MAX_RECORDS=1000
