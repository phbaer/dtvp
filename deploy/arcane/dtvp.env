# Non-secret DTVP runtime configuration. Git-managed deployments may customize
# this file in their deployment branch.
DTVP_ENVIRONMENT=production

# Independently operated vulnerability backend.
DTVP_VULNERABILITY_BACKEND_ID=
DTVP_VULNERABILITY_BACKEND_TYPE=
DTVP_VULNERABILITY_BACKEND_LABEL=
DTVP_VULNERABILITY_BACKEND_API_URL=

# Public URL and reverse-proxy boundary.
DTVP_CONTEXT_PATH=/
DTVP_FRONTEND_URL=https://dtvp.example.com
DTVP_ALLOWED_HOSTS=dtvp.example.com
DTVP_TRUSTED_PROXY_CIDRS=
DTVP_CORS_ORIGINS=

# Production OIDC and session policy. Secret values are supplied separately.
DTVP_OIDC_AUTHORITY=
DTVP_OIDC_CLIENT_ID=
DTVP_OIDC_REDIRECT_URI=https://dtvp.example.com/auth/callback
DTVP_OIDC_ALLOWED_ALGORITHMS=RS256
DTVP_OIDC_TRANSACTION_TTL_SECONDS=300
DTVP_SESSION_TTL_SECONDS=28800
DTVP_SESSION_COOKIE_SECURE=true

# Local state, health policy, and optional integrations.
DTVP_SECURITY_AUDIT_PATH=data/security_audit.jsonl
DTVP_SECURITY_AUDIT_FSYNC=false
DTVP_STORAGE_MIN_FREE_BYTES=134217728
# Arcane volume backups do not write DTVP's backup-status marker.
DTVP_BACKUP_MAX_AGE_SECONDS=0
DTVP_TMRESCORE_URL=
DTVP_JIRA_CREATE_URL=
DTVP_CODE_ANALYSIS_URL=http://agentyzer:8000
DTVP_AUTO_CODE_ANALYSIS_ENABLED=false
