# Override the complete reference only when intentionally updating the pinned base.
ARG ALPINE_IMAGE=alpine:3.24.1@sha256:28bd5fe8b56d1bd048e5babf5b10710ebe0bae67db86916198a6eec434943f8b
FROM ${ALPINE_IMAGE}

# The Docker CLI is used only to pause and resume the DTVP container.
RUN --mount=type=secret,id=ca-certs,target=/tmp/ca-certs.crt \
    if [ -s /tmp/ca-certs.crt ]; then \
        cat /tmp/ca-certs.crt >> /etc/ssl/certs/ca-certificates.crt; \
    fi \
    && apk add --no-cache docker-cli

COPY --chmod=0555 scripts/backup-compose-state-container.sh /usr/local/bin/dtvp-backup
COPY --chmod=0555 scripts/run-backup-scheduler.sh /usr/local/bin/dtvp-backup-scheduler

ENV HOME=/tmp
WORKDIR /app
ENTRYPOINT ["/usr/local/bin/dtvp-backup-scheduler"]
