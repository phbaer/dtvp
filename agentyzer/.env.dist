# ===================================================================== #
# Agentyzer — environment variables                                      #
# ===================================================================== #
# Copy this file to .env and adjust the values for your environment.

# --- General --------------------------------------------------------- #

# Logging verbosity (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Directory used to clone / cache repositories for analysis
AGENTYZER_REPOS_DIR=repos

# Directory containing repos.yaml.
#
# Local default: config
# Container default: /app/config
#
# Prompt bundles fall back to the defaults shipped in the image when this
# directory does not contain an override file for a given bundle.
AGENTYZER_CONFIG_DIR=config

# --- LLM backend ---------------------------------------------------- #

# Which LLM backend to use: "ollama" (default) or "openwebui"
LLM_BACKEND=ollama

# --- Ollama ---------------------------------------------------------- #

# Ollama API base URL
OLLAMA_HOST=http://localhost:11434

# Ollama model name
OLLAMA_MODEL=mistral

# --- Open WebUI ------------------------------------------------------ #

# Open WebUI API base URL
OPENWEBUI_HOST=http://localhost:3000

# Open WebUI model name
OPENWEBUI_MODEL=mistral

# Open WebUI API key (required when using openwebui backend)
OPENWEBUI_API_KEY=

# Native OpenAI-style tool calls for the research loop: auto or off
OPENWEBUI_TOOL_CALLS=auto
