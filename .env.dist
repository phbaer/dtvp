DTVP_ENVIRONMENT=production
# Stable, non-secret identity for the selected vulnerability-management instance.
DTVP_VULNERABILITY_BACKEND_ID=
DTVP_VULNERABILITY_BACKEND_TYPE=
DTVP_VULNERABILITY_BACKEND_LABEL=
DTVP_VULNERABILITY_BACKEND_API_URL=
DTVP_VULNERABILITY_BACKEND_API_KEY=
DTVP_VULNERABILITY_BACKEND_API_KEY_FILE=
# Optional separate credential for backend import/archive-restore operations.
DTVP_VULNERABILITY_BACKEND_IMPORT_API_KEY=
DTVP_VULNERABILITY_BACKEND_IMPORT_API_KEY_FILE=
# Host port for the DTVP Docker Compose nginx gateway.
DTVP_HTTP_PORT=80
DTVP_SERVER_NAME=localhost
DTVP_ALLOWED_HOSTS=
DTVP_TRUSTED_PROXY_CIDRS=
DTVP_SECURITY_AUDIT_PATH=data/security_audit.jsonl
DTVP_SECURITY_AUDIT_FSYNC=false
DTVP_SECURITY_AUDIT_MAX_BYTES=104857600
DTVP_SECURITY_AUDIT_BACKUP_COUNT=10
# Fail startup if a second DTVP process targets the same local state volume.
DTVP_INSTANCE_LOCK_PATH=data/dtvp-runtime.lock
# Persistent-storage health and external-backup freshness monitoring.
DTVP_STORAGE_MIN_FREE_BYTES=134217728
DTVP_BACKUP_STATUS_PATH=data/backup_status.json
# Set a non-zero recovery-policy threshold after the first verified backup.
DTVP_BACKUP_MAX_AGE_SECONDS=0
# Optional Compose-native backup scheduler. Enable with COMPOSE_PROFILES=backup.
COMPOSE_PROFILES=
DTVP_BACKUP_IMAGE=dtvp-backup-scheduler:local
DTVP_BACKUP_PATH=./backups
DTVP_BACKUP_INTERVAL_SECONDS=86400
DTVP_BACKUP_INITIAL_DELAY_SECONDS=300
DTVP_BACKUP_RETRY_SECONDS=3600
DTVP_DOCKER_SOCKET_PATH=/var/run/docker.sock
DTVP_RATE_LIMIT_WINDOW_SECONDS=60
DTVP_AUTH_RATE_LIMIT=30
DTVP_EXPENSIVE_RATE_LIMIT=20
DTVP_MUTATION_RATE_LIMIT=120
# UID/GID used by the non-root DTVP container for the ./data bind mount
DTVP_RUNTIME_UID=1000
DTVP_RUNTIME_GID=1000
# Local path for backend-scoped cache data and pending updates.
DTVP_VULNERABILITY_BACKEND_CACHE_PATH=data/backend_cache
DTVP_VULNERABILITY_BACKEND_CACHE_REFRESH_SECONDS=60
# Local path for manual project archive exports, uploaded import previews, and scheduled snapshots
DTVP_PROJECT_ARCHIVE_PATH=data/project_archives
# Also write a stable, expanded, Git-friendly archive tree for each exported project
DTVP_PROJECT_ARCHIVE_EXPANDED_ENABLED=false
# Local path for expanded archive trees intended for Git history
DTVP_PROJECT_ARCHIVE_EXPANDED_PATH=data/project_archives_git
# Set to true to periodically export project archives in the background
DTVP_PROJECT_ARCHIVE_SNAPSHOT_ENABLED=false
# Snapshot interval in seconds
DTVP_PROJECT_ARCHIVE_INTERVAL_SECONDS=86400
# Number of recent archive ZIPs retained per project name
DTVP_PROJECT_ARCHIVE_RETENTION_COUNT=30
# Optional comma-separated project names for scheduled snapshots; empty uses active/cached projects
DTVP_PROJECT_ARCHIVE_INCLUDE=
# Maximum uploaded archive size and bounded ZIP expansion controls
DTVP_PROJECT_ARCHIVE_UPLOAD_MAX_BYTES=104857600
DTVP_PROJECT_ARCHIVE_MAX_FILES=10000
DTVP_PROJECT_ARCHIVE_MAX_MEMBER_BYTES=104857600
DTVP_PROJECT_ARCHIVE_MAX_UNCOMPRESSED_BYTES=524288000
DTVP_PROJECT_ARCHIVE_MAX_COMPRESSION_RATIO=200

# Optional Docker Compose archive-git helper settings. These are used by the
# dtvp-archive-git-push profile, not by the DTVP backend.
DTVP_ARCHIVE_GIT_REMOTE=
DTVP_ARCHIVE_GIT_BRANCH=main
DTVP_ARCHIVE_GIT_AUTHOR_NAME=DTVP Archive Bot
DTVP_ARCHIVE_GIT_AUTHOR_EMAIL=dtvp-archive@example.invalid
DTVP_ARCHIVE_GIT_SSH_KEY_FILE=/run/secrets/dtvp_archive_deploy_key
DTVP_ARCHIVE_GIT_KNOWN_HOSTS_FILE=/run/secrets/known_hosts
# Host files mounted only into the optional archive helper.
DTVP_ARCHIVE_GIT_SSH_KEY_HOST_FILE=./secrets/dtvp_archive_deploy_key
DTVP_ARCHIVE_GIT_KNOWN_HOSTS_HOST_FILE=./secrets/known_hosts

DTVP_OIDC_AUTHORITY=
DTVP_CONTEXT_PATH=
DTVP_FRONTEND_URL=
DTVP_OIDC_REDIRECT_URI=
# Generate with: openssl rand -hex 32
DTVP_SESSION_SECRET_KEY=
DTVP_SESSION_SECRET_KEY_FILE=
DTVP_SESSION_PREVIOUS_SECRET_KEY=
DTVP_SESSION_PREVIOUS_SECRET_KEY_FILE=
DTVP_SESSION_TTL_SECONDS=28800
DTVP_SESSION_COOKIE_SECURE=true
DTVP_OIDC_CLIENT_ID=
DTVP_OIDC_CLIENT_SECRET=
DTVP_OIDC_CLIENT_SECRET_FILE=
DTVP_OIDC_ALLOWED_ALGORITHMS=RS256
DTVP_OIDC_TRANSACTION_TTL_SECONDS=300
DTVP_VERSION_FETCH_CONCURRENCY=4
# Maximum concurrent backend assessment reads/writes per operation
DTVP_ASSESSMENT_IO_CONCURRENCY=4
# Attempts for transient 408/429/5xx assessment-write failures
DTVP_ASSESSMENT_WRITE_MAX_ATTEMPTS=3
# Maximum bytes accepted for reviewer settings-file uploads
DTVP_SETTINGS_UPLOAD_MAX_BYTES=1048576
# Maximum bytes accepted for each tmrescore multipart file
DTVP_TMRESCORE_UPLOAD_MAX_BYTES=20971520

# Threat-model rescoring integration (optional)
DTVP_TMRESCORE_URL=
DTVP_TMRESCORE_TIMEOUT_SECONDS=180
DTVP_TMRESCORE_CACHE_PATH=data/tmrescore_proposals.json
DTVP_TMRESCORE_OLLAMA_MODEL=qwen2.5:7b
DTVP_TMRESCORE_TASK_TTL_SECONDS=3600

# Code analysis integration (optional)
DTVP_CODE_ANALYSIS_URL=
DTVP_CODE_ANALYSIS_TIMEOUT_SECONDS=300
DTVP_CODE_ANALYSIS_STATUS_TIMEOUT_SECONDS=5
DTVP_CODE_ANALYSIS_SERVICE_TOKEN=
DTVP_CODE_ANALYSIS_SERVICE_TOKEN_FILE=
DTVP_CODE_ANALYSIS_ADMIN_TOKEN=
DTVP_CODE_ANALYSIS_ADMIN_TOKEN_FILE=
DTVP_CODE_ANALYSIS_MODEL=
DTVP_CODE_ANALYSIS_LLM_BACKEND=
DTVP_CODE_ANALYSIS_LLM_PROVIDER=
DTVP_ANALYSIS_QUEUE_CAPACITY=1
DTVP_ANALYSIS_QUEUE_TTL_SECONDS=3600
DTVP_AUTO_ANALYSIS_GUIDANCE_PATH=data/auto_analysis_guidance.json

# Agentyzer code-analysis service used by Docker Compose
AGENTYZER_PORT=8095
AGENTYZER_LOG_LEVEL=INFO
AGENTYZER_ENVIRONMENT=production
# Generate two distinct values with `openssl rand -hex 32`; DTVP and Agentyzer
# receive both values automatically in the root Compose stack.
AGENTYZER_SERVICE_TOKEN=
AGENTYZER_SERVICE_TOKEN_FILE=
AGENTYZER_SERVICE_TOKEN_PREVIOUS=
AGENTYZER_SERVICE_TOKEN_PREVIOUS_FILE=
AGENTYZER_ADMIN_TOKEN=
AGENTYZER_ADMIN_TOKEN_FILE=
AGENTYZER_ADMIN_TOKEN_PREVIOUS=
AGENTYZER_ADMIN_TOKEN_PREVIOUS_FILE=
AGENTYZER_MAX_CONCURRENT_JOBS=1
AGENTYZER_MAX_QUEUED_JOBS=100
AGENTYZER_MAX_ACTIVE_JOBS_PER_OWNER=10
AGENTYZER_WORKTREE_RETENTION_SECONDS=86400
AGENTYZER_INSTANCE_LOCK_PATH=/app/repos/.agentyzer-runtime.lock
AGENTYZER_STORAGE_MIN_FREE_BYTES=134217728
AGENTYZER_LLM_BACKEND=ollama
AGENTYZER_OLLAMA_HOST=http://host.docker.internal:11434
AGENTYZER_OLLAMA_MODEL=mistral
AGENTYZER_OPENWEBUI_HOST=http://host.docker.internal:3000
AGENTYZER_OPENWEBUI_MODEL=mistral
AGENTYZER_OPENWEBUI_API_KEY=
AGENTYZER_OPENWEBUI_API_KEY_FILE=
AGENTYZER_OPENWEBUI_TOOL_CALLS=auto
AGENTYZER_OPENWEBUI_CONTEXT_WINDOW=0
AGENTYZER_OPENWEBUI_CONTEXT_SAFETY_MARGIN=256
AGENTYZER_OPENWEBUI_CONTEXT_RETRIES=2
AGENTYZER_OPENWEBUI_MIN_COMPLETION_TOKENS=256

# Build info
DTVP_BUILD_COMMIT=dev
# Set a default project filter for the dashboard
DTVP_DEFAULT_PROJECT_FILTER=
# Comma-separated attribution-age filter presets for project filters
DTVP_ATTRIBUTION_AGE_FILTER_DAYS=7d,14d,28d
# Optional Jira create-screen URL. When set, ticket drafts can be copied and opened in Jira.
DTVP_JIRA_CREATE_URL=
