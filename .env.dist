DTVP_DT_API_KEY=
# URL of the upstream Dependency Track API
DTVP_DT_API_URL=
DTVP_OIDC_AUTHORITY=
DTVP_CONTEXT_PATH=
DTVP_FRONTEND_URL=
DTVP_OIDC_REDIRECT_URI=
DTVP_SESSION_SECRET_KEY=
DTVP_OIDC_CLIENT_ID=
DTVP_OIDC_CLIENT_SECRET=
DTVP_VERSION_FETCH_CONCURRENCY=4

# Threat-model rescoring integration (optional)
DTVP_TMRESCORE_URL=
DTVP_TMRESCORE_TIMEOUT_SECONDS=180
DTVP_TMRESCORE_CACHE_PATH=data/tmrescore_proposals.json
DTVP_TMRESCORE_OLLAMA_MODEL=qwen2.5:7b
DTVP_TMRESCORE_TASK_TTL_SECONDS=3600

# Build info
DTVP_BUILD_COMMIT=dev
# Set a default project filter for the dashboard
DTVP_DEFAULT_PROJECT_FILTER=
